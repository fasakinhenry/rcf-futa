# ── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com (free tier)
# Get these from: Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Used by the Supabase Edge Function that sends Resend emails
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Create a project at https://cloudinary.com (free tier: 25GB storage)
# Cloud name: Dashboard → top left
# Upload preset: Settings → Upload → Add upload preset → set to "Unsigned"
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=rcf_futa_unsigned

# ── Admin credentials ─────────────────────────────────────────────────────────
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change_me_before_deploying

# ── Resend ───────────────────────────────────────────────────────────────────
# Used by the Supabase Edge Function to send playlist and approval alerts
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=RCF FUTA <updates@yourdomain.com>

# ── Site URL ──────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://rcf-futa.vercel.app
SITE_URL=https://rcf-futa.vercel.app
